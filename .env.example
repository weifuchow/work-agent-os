# App
APP_NAME=work-agent-os
DEBUG=true
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=sqlite+aiosqlite:///data/db/app.sqlite

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# Memory (disabled by default; set true to opt in)
ENABLE_MEMORY_TOOLS=false
ENABLE_MEMORY_CONSOLIDATION=false

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_BOT_NAME=WorkAgent
FEISHU_DRIVE_UPLOAD_ENABLED=true
# Empty means Drive root for the current app identity.
FEISHU_DRIVE_FOLDER_TOKEN=
FEISHU_DRIVE_BASE_URL=https://k32rofd4qx.feishu.cn
FEISHU_DRIVE_INTERNAL_LINK_ENABLED=false

# GitLab
GITLAB_TOKEN=
GITLAB_PROJECT_URL=http://git.standard-robots.com/cybertron/allspark

# Codex
CODEX_EXEC_TIMEOUT_SECONDS=2400
